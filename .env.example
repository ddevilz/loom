# Loom Configuration
# Copy to .env in your project root and uncomment what you need.

# Override the SQLite database path.
# Default: ~/.loom/projects/<repo-name>.db (auto-detected from git root)
# LOOM_DB_PATH=~/.loom/loom.db

# Log verbosity: DEBUG | INFO | WARNING | ERROR
# Default: WARNING
# LOOM_LOG_LEVEL=INFO
