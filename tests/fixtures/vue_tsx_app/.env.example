# Vue.js Application Environment Variables
VITE_APP_NAME=TaskManager
VITE_APP_VERSION=1.0.0
VITE_API_URL=http://localhost:3000/api
VITE_API_KEY=your_api_key_here
VITE_API_SECRET=your_api_secret_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/taskdb

# Authentication
AUTH_SECRET=your_auth_secret_key
JWT_SECRET=your_jwt_secret_key
SESSION_SECRET=your_session_secret

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=false

# External Services
STRIPE_PUBLIC_KEY=pk_test_1234567890
STRIPE_SECRET_KEY=sk_test_0987654321
SENDGRID_API_KEY=SG.1234567890
